<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar" />

    <!-- Cold-start splash screen (androidx.core:core-splashscreen). -->
    <style name="Theme.OctoJotter.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/octo_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>
</resources>
